DOCKER Compose:

Docker Compose is a tool used to define and run multiple Docker containers (services) using a single YAML configuration file.

version: "3.8"

services:

  accounts:
    image: accounts-service
    ports:
      - "8081:8080"

  loans:
    image: loans-service
    ports:
      - "8082:8080"

  cards:
    image: cards-service
    ports:
      - "8083:8080"


version: "3.8"

services:

  mysql:
    image: mysql:8
    container_name: mysql-db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: bankdb
    ports:
      - "3306:3306"

  accounts:
    image: accounts-service
    build: ./accounts
    ports:
      - "8081:8080"
    depends_on:
      - mysql

  loans:
    image: loans-service
    build: ./loans
    ports:
      - "8082:8080"
    depends_on:
      - mysql

  cards:
    image: cards-service
    build: ./cards
    ports:
      - "8083:8080"
    depends_on:
      - MySQL

